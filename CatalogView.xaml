<UserControl x:Class="BookPlatformWPF.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox x:Name="txtSearch" Width="300" Height="35" Margin="0,0,10,0"
                     TextChanged="txtSearch_TextChanged"
                     ToolTip="Поиск по названию или автору" FontSize="14"/>

            <ComboBox x:Name="cmbGenre" Width="200" Height="35" Margin="0,0,10,0"
                      SelectionChanged="cmbGenre_SelectionChanged">
                <ComboBoxItem Content="Все жанры" IsSelected="True"/>
            </ComboBox>

            <ComboBox x:Name="cmbSort" Width="200" Height="35"
                      SelectionChanged="cmbSort_SelectionChanged">
                <ComboBoxItem Content="По названию (А-Я)" IsSelected="True"/>
                <ComboBoxItem Content="По названию (Я-А)"/>
                <ComboBoxItem Content="По рейтингу (высокий)"/>
                <ComboBoxItem Content="По рейтингу (низкий)"/>
            </ComboBox>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding FilteredBooks}" Margin="10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Обложка" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Books.CoverPath}" Width="70" Height="95" Stretch="UniformToFill"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="280"/>
                    <GridViewColumn Header="Автор" DisplayMemberBinding="{Binding DisplayName}" Width="180"/>
                    <GridViewColumn Header="Жанры" Width="220">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GenresString}" 
                       TextWrapping="Wrap" 
                       ToolTip="{Binding GenresString}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Рейтинг" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AvgRating, StringFormat={}{0:0.0}}" 
                                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Действия" Width="220">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Открыть" Click="OpenBook_Click"
                                            Margin="0,0,8,0" Padding="10,5" Tag="{Binding Book}"/>
                                    <Button Content="В список" Click="AddToList_Click"
                                           Tag="{Binding Book}" Padding="10,5"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>