<UserControl x:Class="BookPlatformWPF.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Padding="20"
                CornerRadius="10"
                BorderBrush="#DDD"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="{Binding User.DisplayName}"
                           FontSize="26"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding User.Email}"
                           FontSize="15"
                           Margin="0,5,0,0"/>

                <TextBlock Text="{Binding User.Roles.RoleName}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,10,0,0"/>


                <Border Background="#FF7F7F"
                        Padding="12"
                        Margin="0,20,0,0"
                        CornerRadius="8"
                        Visibility="{Binding FrozenVisibility}">

                    <StackPanel>

                        <TextBlock Text="Аккаунт заморожен"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="DarkRed"/>

                        <TextBlock Text="{Binding FreezeReason}"
                                   Margin="0,5,0,10"
                                   TextWrapping="Wrap"/>

                        <Button Content="Оспорить блокировку"
                                Width="180"
                                Height="32"
                                HorizontalAlignment="Left"
                                Click="AppealFreeze_Click"/>

                    </StackPanel>

                </Border>


                <WrapPanel Margin="0,20,0,0">

                    <Button Content="Подать заявку на роль автора"
                            Width="220"
                            Height="35"
                            Margin="0,0,10,0"
                            Click="RequestAuthor_Click"
                            Visibility="{Binding AuthorRequestVisibility}"/>

                    <Button Content="Сменить пользователя"
                            Width="180"
                            Height="35"
                            Click="Unregistration_Click"/>

                </WrapPanel>

            </StackPanel>

        </Border>


        <TextBlock Grid.Row="1"
                   Text="Мои отзывы"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,20,0,10"/>

        <ListView Grid.Row="2"
                  ItemsSource="{Binding UserReviews}">

            <ListView.View>
                <GridView>

                    <GridViewColumn Header="Книга"
                                    Width="220"
                                    DisplayMemberBinding="{Binding Books.Title}"/>

                    <GridViewColumn Header="Оценка"
                                    Width="80"
                                    DisplayMemberBinding="{Binding Rating}"/>

                    <GridViewColumn Header="Отзыв"
                                    Width="450"
                                    DisplayMemberBinding="{Binding ReviewText}"/>

                </GridView>

            </ListView.View>

        </ListView>

    </Grid>

</UserControl>