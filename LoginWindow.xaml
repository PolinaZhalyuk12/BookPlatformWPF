<Window x:Class="BookPlatformWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="350" Width="400" ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Вход в систему" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Логин"/>
            <TextBox x:Name="txtLogin" Tag="Логин" Margin="0,5"/>
            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="txtPassword" Margin="0,5"/>
            <Button Content="Войти" Click="BtnLogin_Click" Margin="0,15"/>
            <Button Content="Регистрация" Click="BtnRegister_Click" Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>