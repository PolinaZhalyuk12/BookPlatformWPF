<Window x:Class="BookPlatformWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши" Height="720" Width="1250"
        Background="WhiteSmoke" WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Width="85" Background="#2C3E50" HorizontalAlignment="Left">
            <StackPanel Margin="5">
                <Button x:Name="btnCatalog" Style="{StaticResource SidebarButton}" ToolTip="Каталог книг" Click="BtnCatalog_Click">📚</Button>
                <Button x:Name="btnLists" Style="{StaticResource SidebarButton}" ToolTip="Списки книг" Click="BtnLists_Click">📖</Button>
                <Button x:Name="btnAuthor" Style="{StaticResource SidebarButton}" ToolTip="Страница автора" Click="BtnAuthor_Click" Visibility="Collapsed">✍️</Button>
                <Button x:Name="btnAdmin" Style="{StaticResource SidebarButton}" ToolTip="Администрирование" Click="BtnAdmin_Click" Visibility="Collapsed">🛠️</Button>
                <Button Style="{StaticResource SidebarButton}" ToolTip="Профиль" Click="BtnProfile_Click">👤</Button>
            </StackPanel>
        </Border>

        <ContentControl x:Name="ContentArea" Margin="85,0,0,0"/>
    </Grid>
</Window>